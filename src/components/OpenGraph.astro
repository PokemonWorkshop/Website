---
import { i18n, validLocale } from '../i18n';
import Logo from '../assets/logo.png'

interface Props {
	title: string;
	seoDescription: string;
	cover: ImageMetadata[] | undefined | null;
	tags: string[] | undefined | null;
  page: string;
}

const { title, seoDescription, cover, page } = Astro.props;
const locale = await i18n('fullLocale', validLocale(Astro.currentLocale));
const alternate = await i18n('fullLocale', validLocale(Astro.currentLocale == 'en' ? 'fr' : 'en'));

const ldJSON = {
"@context": "https://schema.org",
"@type": "Organization",
"name": "Pokémon Workshop",
"url": "https://pokemonworkshop.com/",
"logo": Logo.src,
"sameAs": [
  "https://twitter.com/PokemonWorkshop",
  "https://www.instagram.com/pokemon.workshop/",
  "https://www.facebook.com/PokemonWorkshop",
  "https://github.com/PokemonWorkshop",
  "https://discord.com/invite/0noB0gBDd91B8pMk"
]
}


---

<meta name="og:site_name" content="Pok&#xE9;mon&#x20;Workshop">
<meta name="og:title" content={title}>
<meta name="og:description" content={seoDescription}>
<meta property="og:url" content=`https://pokemonworkshop.com/${page}` />
<meta property="og:locale" content={locale} />
<meta property="og:locale:alternate" content={alternate} />
{ cover ? <meta name="og:image" content={cover[0].src}> : <></> }
<script type="application/ld+json" set:html={JSON.stringify(ldJSON)}></script>
