---
interface Props {
  href: string;
}
---

<a class="light-cta" href={Astro.props.href}><slot /></a>

<style>
  .light-cta {
    background: #000;
    color: #fff;
    display: inline-flex;
    font-weight: 500;
    justify-content: center;
    padding: 0.75rem 1.5rem;
    border-radius: 0.5rem;
  }

  .light-cta:hover {
    background: none;
    color: #000;
    outline: 2px solid #000;
    outline-offset: -2px;
    animation: 0.2s ease infinite rotate;
    transition-duration: 0.2s;
  }

  a.light-cta {
    text-decoration: none;
  }
</style>
